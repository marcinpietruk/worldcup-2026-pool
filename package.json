{
  "name": "worldcup-2026-pool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:seed": "node --env-file=.env --import tsx scripts/seed.ts",
    "db:sync": "node --env-file=.env --import tsx scripts/sync.ts",
    "db:reset": "node --env-file=.env --import tsx scripts/devResults.ts reset",
    "dev:results": "node --env-file=.env --import tsx scripts/devResults.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "openai": "^6.42.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "puppeteer-core": "^25.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
