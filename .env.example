# Copy to .env (local) or set these in the Vercel dashboard (production).

# Postgres connection string. Local dev uses the Docker container on :5433.
# Production: paste the connection string from Neon / Supabase / Vercel Postgres.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# Password for the /admin panel (results override + scoring config). Pick anything.
ADMIN_PASSWORD="choose-a-strong-password"

# --- Live results provider (optional; without one, use admin manual entry) ---
# Preferred: football-data.org — free tier covers the World Cup.
# Register a free token at https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=""
FOOTBALL_DATA_COMP="WC"

# Fallback: API-Football (api-sports.io). Its FREE tier does NOT include season
# 2026 (only 2022-2024) — needs a paid plan for WC2026.
FOOTBALL_API_KEY=""
FOOTBALL_API_HOST="v3.football.api-sports.io"
FOOTBALL_LEAGUE_ID="1"
FOOTBALL_SEASON="2026"

# Any random string. Lets an external scheduler (GitHub Actions / cron-job.org)
# safely call the live-refresh route: /api/refresh?secret=REFRESH_SECRET
# (also guards the daily Slack digest: /api/slack/digest?secret=REFRESH_SECRET)
REFRESH_SECRET="choose-a-random-string"

# --- Slack daily digest (optional) ---
# Posts a morning recap (standings, results, today's fixtures, awards) to a Slack
# channel via a daily GitHub Action. Set up a Slack *app*:
#   1. https://api.slack.com/apps -> Create New App -> From scratch.
#   2. OAuth & Permissions -> Bot Token Scopes -> add `chat:write`.
#   3. Install to Workspace -> copy the "Bot User OAuth Token" (xoxb-...).
#   4. In Slack, invite the bot to the channel: /invite @your-app-name
#   5. Channel id: right-click the channel -> View channel details -> bottom (C...).
SLACK_BOT_TOKEN=""
SLACK_CHANNEL_ID=""

# Public base URL of the deployed app — used for the digest's "Open the table"
# link. e.g. https://worldcup-2026-pool-indol.vercel.app
APP_URL=""

# --- AI commentary for the digest (optional) ---
# Adds a short football-commentator-style intro to the digest, generated from the
# day's facts. Uses the OpenAI Responses API. Without a key, the digest still
# posts, just without the flourish. GPT-5.4 nano is ~$0.0002/day here (pennies/mo).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-nano" # model name, or the Azure *deployment* name

# Using Azure OpenAI? Set this to your resource's v1 endpoint and put the Azure
# key in OPENAI_API_KEY above (the standard SDK works against Azure's v1 surface).
# e.g. https://<resource>.cognitiveservices.azure.com/openai/v1/
AZURE_OPENAI_ENDPOINT=""
